{
  "name": "UserSettings",
  "type": "object",
  "properties": {
    "telegram_chat_id": {
      "type": "string"
    },
    "alpaca_api_key": {
      "type": "string"
    },
    "alpaca_secret_key": {
      "type": "string"
    },
    "alpaca_paper": {
      "type": "boolean",
      "default": true
    },
    "openai_api_key": {
      "type": "string"
    },
    "finnhub_api_key": {
      "type": "string"
    },
    "polygon_api_key": {
      "type": "string"
    },
    "fred_api_key": {
      "type": "string"
    },
    "briefing_time": {
      "type": "string",
      "default": "08:00"
    },
    "briefing_enabled": {
      "type": "boolean",
      "default": false
    },
    "briefing_tickers": {
      "type": "string"
    },
    "preferred_model": {
      "type": "string",
      "enum": [
        "gpt-4o",
        "gpt-4o-mini",
        "gpt-4-turbo"
      ],
      "default": "gpt-4o-mini"
    },
    "risk_tolerance": {
      "type": "string",
      "enum": [
        "conservative",
        "moderate",
        "aggressive"
      ],
      "default": "moderate"
    }
  },
  "rls": {
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "write": {
      "created_by_id": "{{user.id}}"
    }
  },
  "required": []
}